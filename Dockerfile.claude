# --- Build stage ---
FROM rust:1-bookworm AS builder
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && cargo build --release && rm -rf src
COPY src/ src/
RUN touch src/main.rs && cargo build --release

# --- Runtime stage ---
FROM node:22-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl && rm -rf /var/lib/apt/lists/*

# Install claude-agent-acp adapter and Claude Code CLI
RUN npm install -g @agentclientprotocol/claude-agent-acp@0.25.0 @anthropic-ai/claude-code --retry 3

ENV HOME=/home/node
WORKDIR /home/node

COPY --from=builder --chown=node:node /build/target/release/agent-broker /usr/local/bin/agent-broker

USER node
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD pgrep -x agent-broker || exit 1
ENTRYPOINT ["agent-broker"]
CMD ["/etc/agent-broker/config.toml"]
